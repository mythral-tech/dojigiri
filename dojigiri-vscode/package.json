{
  "name": "dojigiri-code-analyzer",
  "displayName": "Dojigiri Code Analyzer",
  "description": "Static analysis with inline diagnostics and one-click fixes powered by Dojigiri",
  "version": "0.1.0",
  "publisher": "dojigiri",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:go",
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "doji.scanFile",
        "title": "Dojigiri: Scan Current File"
      },
      {
        "command": "doji.scanWorkspace",
        "title": "Dojigiri: Scan Workspace"
      }
    ],
    "configuration": {
      "title": "Dojigiri",
      "properties": {
        "doji.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python interpreter with dojigiri installed"
        },
        "doji.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan files on save"
        },
        "doji.minSeverity": {
          "type": "string",
          "default": "warning",
          "enum": [
            "info",
            "warning",
            "critical"
          ],
          "description": "Minimum severity level to display"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
