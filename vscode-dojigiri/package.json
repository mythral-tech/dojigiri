{
  "name": "dojigiri",
  "displayName": "Dojigiri Security Scanner",
  "description": "VS Code integration for the Dojigiri security scanner - find vulnerabilities in Python, JavaScript, TypeScript, Go, and Rust code.",
  "version": "0.1.0",
  "publisher": "inklling",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Inklling/dojigiri"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:go",
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dojigiri.scanFile",
        "title": "Dojigiri: Scan Current File"
      },
      {
        "command": "dojigiri.scanWorkspace",
        "title": "Dojigiri: Scan Workspace"
      }
    ],
    "configuration": {
      "title": "Dojigiri",
      "properties": {
        "dojigiri.path": {
          "type": "string",
          "default": "dojigiri",
          "description": "Path to the dojigiri executable or module name."
        },
        "dojigiri.minSeverity": {
          "type": "string",
          "default": "warning",
          "enum": [
            "critical",
            "warning",
            "info"
          ],
          "description": "Minimum severity level to report."
        },
        "dojigiri.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run scan automatically when a file is saved."
        },
        "dojigiri.runOnType": {
          "type": "boolean",
          "default": false,
          "description": "Run scan as you type (debounced, 1.5s delay)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
